# Supabase (production — set these in Vercel Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (SEO, sitemap, ads.txt)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AdSense (after applying at https://adsense.google.com)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_HOME=
NEXT_PUBLIC_ADSENSE_SLOT_QUIZ=
NEXT_PUBLIC_ADSENSE_SLOT_RESULTS=

# Local dev without Supabase: leave both empty → file storage in data/ folder
