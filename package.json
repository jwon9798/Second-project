{
  "name": "clipquiz",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:quizzes": "node scripts/generate-global-quizzes.mjs",
    "prebuild": "npm run generate:icons",
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
